    # Stocker la matrice de confusion (format 2x2 constant)
    confusion_matrices[name] = confusion_matrix(y_test, y_hat, labels=[0, 1])
    y_proba = est.predict_proba(X_test)[:, 1] if hasattr(est, 'predict_proba') else None
    if y_proba is not None:
        test_probabilities[name] = y_proba

    metrics_row = {
        'model': name,
        'best_params': search.best_params_,
        'accuracy': accuracy_score(y_test, y_hat),
        'precision': precision_score(y_test, y_hat, zero_division=0),
        'recall': recall_score(y_test, y_hat, zero_division=0),
        'f1': f1_score(y_test, y_hat, zero_division=0),
        'roc_auc': roc_auc_score(y_test, y_proba) if y_proba is not None else np.nan,
    }
    results.append(metrics_row)
